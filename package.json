{
  "name": "stk",
  "version": "0.1.0",
  "description": "Chrome extension to capture web page content and send to Kindle as epub",
  "private": true,
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "test": "jest",
    "test:integration": "playwright test",
    "pack": "cd dist && zip -r ../stk-extension.zip . -x '*.map' && echo 'Packaged: stk-extension.zip'"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "dompurify": "^3.1.6",
    "emailjs-com": "^3.2.0",
    "epub-gen-memory": "^1.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/chrome": "^0.0.268",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^29.5.12",
    "copy-webpack-plugin": "^12.0.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.92.0",
    "webpack-cli": "^5.1.4"
  }
}
